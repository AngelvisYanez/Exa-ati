# ===================================================
# ATI-EXA — Variables de Entorno para Plesk (Docker)
# ===================================================
# Copia este archivo como .env y configura los valores:
#   cp .env.plesk.example .env
#
# IMPORTANTE: Este archivo NO debe subirse a Git.
# ===================================================

# ─── ENTORNO ────────────────────────────────────────────────
NODE_ENV=production
HEADLESS=true

# ─── BASE DE DATOS ──────────────────────────────────────────
# Opción 1 — PostgreSQL local (contenedor Docker)
# Si usas el servicio 'db' en docker-compose.plesk.yml:
DATABASE_URL=postgresql://postgres:postgres@db:5432/exa_ati
# DIRECT_DATABASE_URL=postgresql://postgres:postgres@db:5432/exa_ati

# Opción 2 — Neon PostgreSQL (cloud) — descomentar y comentar Opción 1
# DATABASE_URL=postgresql://neondb_owner:TU_PASSWORD@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
# DIRECT_DATABASE_URL=postgresql://neondb_owner:TU_PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── SEGURIDAD ──────────────────────────────────────────────
# Genera secretos seguros: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sri-jwt-secret-key-32bytes-long-now
JWT_EXPIRATION=24h
ENCRYPTION_KEY=12345678901234567890123456789012
ENCRYPTION_SALT=sri-salt-1234

# ─── SRI ECUADOR ───────────────────────────────────────────
SRI_AMBIENTE=1
SRI_WSDL_TIMEOUT_MS=25000
SRI_SOAP_TIMEOUT_MS=45000
SRI_SOAP_MAX_RETRIES=3
SRI_AUTH_DELAY_MS=2000
SRI_POLLING_MAX_HOURS=24
SRI_POLLING_BATCH_LIMIT=50

# ─── CRON ───────────────────────────────────────────────────
CRON_SECRET=cambiar-por-un-secreto-seguro

# ─── SCRAPING / ANTICAPTCHA ─────────────────────────────────
ANTICAPTCHA_KEY=
# SCRAPELESS_API_KEY=sk_...

# ─── IA — Chat tributario ──────────────────────────────────
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── DIRECTORIOS ───────────────────────────────────────────
XMLS_DIR=/app/downloads/xmls
CERTS_DIR=/app/downloads/certs
PDFS_DIR=/app/downloads/pdfs
TEMPLATES_DIR=/app/downloads/templates

# ─── NEXT.JS ────────────────────────────────────────────────
# Cambia tu-dominio.com por tu dominio real en Plesk
NEXT_PUBLIC_APP_URL=https://tu-dominio.com
NEXT_PUBLIC_DEV_MODE=false

# ─── APP ────────────────────────────────────────────────────
HTTP_USE_LISTADO_TXT=true
