# ===================================================
# ATI-EXA Frontend — Variables de Entorno
# ===================================================

# ─── BASE DE DATOS ───────────────────────────────────────────────────────────

# PRODUCCIÓN (Neon PostgreSQL — activa cuando DATABASE_URL está definido)
# Obtén estas URLs en: https://neon.tech → tu proyecto → Connection Details
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/exa_ati?sslmode=require
# DIRECT_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/exa_ati?sslmode=require

# DESARROLLO LOCAL (MySQL — activo cuando DATABASE_URL NO está definido)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_sri
DB_USER=root
DB_PASSWORD=

# ─── SEGURIDAD ────────────────────────────────────────────────────────────────
JWT_SECRET=sri-jwt-secret-key-32bytes-long-now
JWT_EXPIRATION=24h
ENCRYPTION_KEY=12345678901234567890123456789012
ENCRYPTION_SALT=sri-salt-1234

# ─── SRI ECUADOR ──────────────────────────────────────────────────────────────
SRI_AMBIENTE=1
SRI_REQUEST_DELAY_MS=150
SRI_SYNC_MAX_LIMIT=500
SRI_WSDL_TIMEOUT_MS=25000
SRI_SOAP_TIMEOUT_MS=45000
SRI_SOAP_MAX_RETRIES=3

# Si el servidor del SRI bloquea IPs (AWS, Vercel, etc), define un Proxy Inverso aquí:
# SRI_PROXY_HOST=proxy-sri.midominio.com

# ─── SCRAPING / ANTICAPTCHA ───────────────────────────────────────────────────
ANTICAPTCHA_KEY=
HEADLESS=true

# ─── IA — Chat tributario ─────────────────────────────────────────────────────
# Fallback global; también configurable en UI por tenant
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-3-7-sonnet-20250219
# LLM_PROVIDER=gemini

# ─── DIRECTORIOS ──────────────────────────────────────────────────────────────
XMLS_DIR=./downloads/xmls
CERTS_DIR=./downloads/certs
PDFS_DIR=./downloads/pdfs

# ─── NEXT.JS ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=nextauth-secret-local-dev-123456
NEXT_PUBLIC_APP_URL=http://localhost:3000

