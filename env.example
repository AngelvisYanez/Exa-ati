# ===================================================
# ATI-EXA Frontend — Variables de Entorno
# ===================================================
# Copia este archivo como .env y configura las variables:
#   cp env.example .env
#
# Para Docker local, la app usará automáticamente
# DATABASE_URL=postgresql://postgres:postgres@db:5432/exa_ati
# definida en docker-compose.yml
# ===================================================

# ─── ENTORNO ────────────────────────────────────────────────────
NODE_ENV=production
HEADLESS=true

# ─── BASE DE DATOS ──────────────────────────────────────────────
# Opción 1 — PostgreSQL local (Docker)
# (definida en docker-compose.yml, no necesitas ponerla aquí)
# DATABASE_URL=postgresql://postgres:postgres@db:5432/exa_ati

# Opción 2 — Neon PostgreSQL (cloud)
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/db?sslmode=require
# DIRECT_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/db?sslmode=require

# ─── SEGURIDAD ──────────────────────────────────────────────────
# Genera secretos con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sri-jwt-secret-key-32bytes-long-now
JWT_EXPIRATION=24h
ENCRYPTION_KEY=12345678901234567890123456789012
ENCRYPTION_SALT=sri-salt-1234

# ─── SRI ECUADOR ───────────────────────────────────────────────
SRI_AMBIENTE=1
SRI_WSDL_TIMEOUT_MS=25000
SRI_SOAP_TIMEOUT_MS=45000
SRI_SOAP_MAX_RETRIES=3
SRI_AUTH_DELAY_MS=2000
SRI_POLLING_MAX_HOURS=24
SRI_POLLING_BATCH_LIMIT=50

# ─── CRON ───────────────────────────────────────────────────────
CRON_SECRET=cambiar-por-un-secreto-seguro

# ─── PROXY INVERSO (opcional) ───────────────────────────────────
# Si el servidor del SRI bloquea IPs (AWS, Vercel, etc.), define un Proxy Inverso aquí:
# SRI_PROXY_HOST=proxy-sri.midominio.com

# ─── SCRAPING / ANTICAPTCHA ─────────────────────────────────────
ANTICAPTCHA_KEY=
# SCRAPELESS_API_KEY=sk_...

# ─── PROXY POOL ─────────────────────────────────────────────────
# WORKER_MAX_CONCURRENT=5
# WORKER_POLL_INTERVAL=10000

# ─── IA — Chat tributario ──────────────────────────────────────
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-3-7-sonnet-20250219
# LLM_PROVIDER=gemini

# ─── DIRECTORIOS ───────────────────────────────────────────────
XMLS_DIR=./downloads/xmls
CERTS_DIR=./downloads/certs
PDFS_DIR=./downloads/pdfs
TEMPLATES_DIR=./downloads/templates

# ─── NEXT.JS ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_DEV_MODE=false
